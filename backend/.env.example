# Copy this to .env and fill in real values

# Database (default: local SQLite)
DATABASE_URL=sqlite+aiosqlite:///./tangents.db

# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# Auth mode: "basic" (single-user self-hosted) or "strict" (JWT multi-user)
AUTH_MODE=basic
ADMIN_USERNAME=admin
ADMIN_PASSWORD=tangents

# JWT (only used when AUTH_MODE=strict)
SECRET_KEY=changeme-in-production

# Optional: override model used for merge synthesis and context compression
# SYNTHESIS_MODEL=gpt-4o-mini

# ─── Live LLM Functional Tests ───────────────────────────────────────────────
# Set LIVE_LLM_TESTS=1 to run tests that call real LLM providers (skipped by default).
# Usage: make test-live  (or: LIVE_LLM_TESTS=1 uv run pytest -m live_llm)
LIVE_LLM_TESTS=0

# At least one provider key is required when LIVE_LLM_TESTS=1
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=...
